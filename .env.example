# RepoLens environment configuration.
# Copy to .env for local development. No AI credentials are required.

NODE_ENV=development

# --- API server ---
SERVER_PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# --- Redis (queue coordination only) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Temporary workspace / retention ---
WORKSPACE_ROOT=./workspace
ANALYSIS_RETENTION_HOURS=24
CLEANUP_INTERVAL_MINUTES=60
STALE_ANALYSIS_HOURS=6

# --- Limits ---
ANALYSIS_WORKER_CONCURRENCY=2
MAX_REPOSITORIES_PER_ANALYSIS=5
MAX_REPOSITORY_SIZE_MB=500
MAX_FILES_PER_REPOSITORY=50000
MAX_ANALYSIS_DURATION_MINUTES=30
GIT_CLONE_TIMEOUT_MINUTES=10
# 0 = full clone (recommended for meaningful contribution metrics); >0 = shallow depth
GIT_CLONE_DEPTH=0
GIT_MAX_COMMITS=5000

# --- API protection ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=100
MAX_REQUEST_BODY_KB=64

# --- Git providers / SSRF allowlist ---
ALLOWED_GIT_HOSTS=github.com,gitlab.com,bitbucket.org
# When true, the API accepts per-repository access tokens so private repos can
# be cloned (GitHub/GitLab/Bitbucket). Tokens are never stored, logged, or
# written to reports. Leave false for a public-only deployment.
ALLOW_PRIVATE_REPOSITORIES=false

# --- AI provider (optional; the app runs fully without any key) ---
# AI_PROVIDER: none | openai-compatible
AI_PROVIDER=none
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# --- Optional GitHub token for higher API rate limits / private repo metadata ---
GITHUB_TOKEN=

# --- Frontend ---
# Base URL the frontend uses to reach the API.
VITE_API_URL=http://localhost:4000
